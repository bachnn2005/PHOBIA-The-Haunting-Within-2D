--- !u!114 &270173525
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 270173521}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 327a81e6848fe1c42876af650baccc6e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  doneWritting: "Kh\xE1 mu\u1ED9n r\u1ED3i... m\xECnh n\xEAn \u0111i ng\u1EE7 th\xEC
    t\u1ED1t h\u01A1n"
  sang: 
  banText: {fileID: 1525446537}
  startScreen: {fileID: 362138217}
  endScreen: {fileID: 1034528538}
  sitEvent: {fileID: 2046387797}
  mainChar: {fileID: 1089917405}
  dialoguePanel: {fileID: 1140222971}
  dialogueText: {fileID: 1937490842}
  index: 0
  dialogue:
  - "C\xF3 l\u1EBD m\xECnh n\xEAn vi\u1EBFt nh\u1EADt k\xED..."
  - "C\xF3 l\u1EBD \u0111\xE2y l\xE0 l\u1EA7n \u0111\u1EA7u ti\xEAn m\xECnh c\xF3
    1 c\u1EA3m gi\xE1c h\u1EA1nh ph\xFAc \u0111\u1EBFn v\u1EADy..."
  - "M\xECnh c\xF3 c\u1EA3m gi\xE1c nh\u01B0 3 ng\xE0y v\u1EEBa qua \u0111\xE3 thay
    \u0111\u1ED5i m\xECnh th\xE0nh m\u1ED9t con ng\u01B0\u1EDDi ho\xE0n to\xE0n kh\xE1c
    v\u1EADy..."
  - "M\xECnh t\u1EF1 tin h\u01A1n, c\u0169ng k\u1EBFt \u0111\u01B0\u1EE3c v\xE0i
    ng\u01B0\u1EDDi b\u1EA1n, vui v\u1EBB h\u01A1n..."
  - "L\xE0m quen v\u1EDBi m\u1ED9t m\xF4i tr\u01B0\u1EDDng m\u1EDBi n\xE0y tuy c\xF3
    h\u01A1i kh\xF3 kh\u0103n nh\u01B0ng \u0111\u1EC1u l\xE0 nh\u1EEFng tr\u1EA3i
    nghi\u1EC7m qu\xFD gi\xE1..."
  - "C\u1EA3m \u01A1n b\u1EA3n th\xE2n v\xEC nh\u1EEFng g\xEC \u0111\xE3 tr\u1EA3i
    qua. Hy v\u1ECDng r\u1EB1ng m\u1ECDi ng\xE0y \u0111\u1EC1u c\xF3 th\u1EC3 t\u01B0\u01A1i
    s\xE1ng."
  wordSpeed: 0.01
  TypingSound: {fileID: 270173526}
  KeyBoard: {fileID: 8300000, guid: 9a56f65675c577c4fb079e66c4b9dbca, type: 3}
