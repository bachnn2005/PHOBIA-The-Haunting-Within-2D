  m_GameObject: {fileID: 1575277090}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fbc45b06aed60be4d838c185d4b09035, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m: {fileID: 1484440504}
  dialoguePanel: {fileID: 1140222971}
  dialogueText: {fileID: 1937490842}
  startScreen: {fileID: 912015098}
  endScreen: {fileID: 1666565788}
  blackScreen: {fileID: 305947351}
  mainChar: {fileID: 1089917405}
  mainCharDream: {fileID: 0}
  dialogue:
  - "C\xF4 gi\xE1o: L\u1EDBp b\u1EAFt \u0111\u1EA7u h\u1ECDc \u0111\u01B0\u1EE3c
    30 ph\xFAt r\u1ED3i. C\xF4 kh\xF4ng \u0111i\u1EC3m danh n\u1EEFa \u0111\xE2u
    nh\xE9."
  - "Tonny: C\xF4 \u01A1i, \u0111\xE2y l\xE0 bu\u1ED5i ngh\u1EC9 cu\u1ED1i c\u1EE7a
    em r\u1ED3i. C\xF4 \u0111i\u1EC3m danh gi\xFAp em \u0111\u01B0\u1EE3c kh\xF4ng
    \u1EA1?"
  - "C\xF4 gi\xE1o: Kh\xF4ng \u0111\u01B0\u1EE3c \u0111\xE2u em. Lu\u1EADt c\u1EE7a
    tr\u01B0\u1EDDng \u0111\xE3 \u0111\u1EC1 ra r\u1EA5t nghi\xEAm kh\u1EAFc v\xE0
    t\u1EA5t c\u1EA3 m\u1ECDi ng\u01B0\u1EDDi \u0111\u1EC1u ph\u1EA3i tu\xE2n th\u1EE7."
  - "Tonny: Nh\u01B0ng m\xE0 c\xF4 \u01A1i l\u1EA7n \u0111\u1EA7u c\u0169ng nh\u01B0
    l\u1EA7n cu\u1ED1i, c\xF4 gi\xFAp em n\u1ED1t l\u1EA7n n\xE0y v\u1EDBi \u1EA1?"
  - "C\xF4 gi\xE1o: N\u1EBFu b\xE2y gi\u1EDD c\xF4 \u0111i\u1EC3m danh cho em th\xEC
    c\xF3 ph\u1EA3i l\xE0 kh\xF4ng c\xF4ng b\u1EB1ng v\u1EDBi c\xE1c b\u1EA1n kh\xE1c
    kh\xF4ng?"
  - "C\xF4 gi\xE1o: N\xF3 c\xF3 th\u1EC3 s\u1EBD t\u1EA1o ra m\u1ED9t ti\u1EC1n l\u1EC7
    x\u1EA5u cho c\xE1c b\u1EA1n kh\xE1c h\u1ECDc theo."
  - ...
  - "Tonny: D\u1EA1 v\u1EADy th\xF4i \u1EA1..."
  - "Tonny: Em ch\xE0o c\xF4..."
  wordSpeed: 0.01
  startTime: 4
  blackScreenTime: 1
